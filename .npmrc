# Seguridad npm

# Bloquea scripts pre/post install de paquetes (evita ejecución de código malicioso al instalar)
ignore-scripts=true

# Fija versiones exactas al instalar (evita actualizaciones inesperadas)
save-exact=true

# Solo instala paquetes publicados hace más de 7 días (10080 minutos)
# Protege contra ataques de typosquatting recientes
minimum-release-age=10080

# Bloquea dependencias transitivas que usen registries externos o exóticos
block-exotic-subdeps=true

# Evita que la confianza de un publisher baje (no-downgrade)
trust-policy=no-downgrade

# Habilita el modelo de permisos de Node.js
node-options=--permission
